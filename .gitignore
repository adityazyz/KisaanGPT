# ═══════════════════════════════════════════════════════════════
#             Never commit generated / installed files
# ═══════════════════════════════════════════════════════════════

# ─── JavaScript / Node.js / pnpm / yarn / npm ──────────────────
**/node_modules/
**/pnpm-lock.yaml.bak
**/.pnpm-debug.log
**/.npm/
**/npm-debug.log
**/yarn-debug.log
**/yarn-error.log

# ─── Next.js ────────────────────────────────────────────────────
**/.next/
**/.next/cache/
**/.next/cache/**/*
**/.swc/

# ─── Build outputs (Vite, esbuild, rollup, webpack, tsc, etc.) ──
**/dist/
**/dist-ssr/
**/build/
**/out/
**/*.tsbuildinfo

# ─── Python ─────────────────────────────────────────────────────
**/__pycache__/
**/*.py[cod]
**/*.pyc
**/*.pyo
**/*.pyd
**/.Python
**/venv/
**/env/
**/.venv/
**/ENV/
**/*.egg-info/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.coverage
**/coverage.xml
**/*.egg-info/
**/*.eggs/

# ─── Testing & coverage tools ───────────────────────────────────
**/coverage/
**/.nyc_output/
**/jest.cache/
**/playwright-report/
**/test-results/

# ─── Editor & OS junk ───────────────────────────────────────────
**/.DS_Store
**/*.swp
**/*.swo
**/*~
**/.idea/
**/.vscode/
**/*.sublime-*

# ─── Local env & secrets ────────────────────────────────────────
**/.env
**/.env.local
**/.env.*.local
**/credentials.json
**/*.secret

# ─── Temporary / tool caches ────────────────────────────────────
**/.cache/
**/.turbo/
**/.nx/cache/
**/.parcel-cache/
**/temp/
**/tmp/

# ─── Docker & build helpers you usually don't commit ────────────
**/docker-compose.override.yml
**/*.dockerignore
**/Dockerfile*
**/docker-compose*